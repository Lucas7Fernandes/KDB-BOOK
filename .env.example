# ════════════════════════════════════════════════════════════════
# KDP COLORBOOK GENERATOR — CONFIGURAÇÃO
# ════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores reais.
# Atenção: variáveis com prefixo VITE_ são expostas no frontend.

# ─── Webhook Make.com (obrigatório) ───
# Endpoint que recebe { animal_en, animal_pt } e retorna a imagem gerada.
VITE_WEBHOOK_URL=https://hook.us2.make.com/seu-webhook-aqui

# ─── Proxy CORS (opcional) ───
# Habilita o proxy corsproxy.io se o webhook bloquear chamadas do browser.
VITE_USE_CORS_PROXY=true

# ─── Configurações de custo ───
VITE_COST_PER_IMAGE=0.03
VITE_INITIAL_BALANCE=5.00

# ─── Anthropic API (opcional, apenas se for usar IA local) ───
# ⚠️  NUNCA exponha chaves reais no frontend em produção.
# Para uso real, crie um endpoint backend (Vercel/Netlify Functions).
# VITE_ANTHROPIC_API_KEY=sk-ant-...
